---
layout: base.njk
seoType: BlogPosting
sectionLabel: Racconti di matrimonio
sectionUrl: /
---
<header class="header"><div class="brand">PHOTO 10.5</div><h1>{{ title }}</h1><p class="subtitle">{{ description }}</p><div class="nav"><a class="btn primary" href="https://photo10-5.com">Torna al sito Photo 10.5</a><a class="btn" href="/">Tutti i racconti</a></div></header><article class="article"><div class="meta">{% if location %}{{ location }}{% endif %}{% if location and date %} · {% endif %}{% if date %}{{ date }}{% endif %}</div>{% if cover %}<img class="cover" src="{{ cover }}" alt="{{ title }}" title="{{ title }}">{% endif %}<div class="article-content">{{ content | safe }}</div>{% if gallery and gallery.length %}<div class="gallery">{% for item in gallery %}{% if item.image %}<img src="{{ item.image }}" alt="{{ title }}" title="{{ title }}">{% else %}<img src="{{ item }}" alt="{{ title }}" title="{{ title }}">{% endif %}{% endfor %}</div>{% endif %}<div class="nav"><a class="btn primary" href="https://photo10-5.com">Torna al sito Photo 10.5</a><a class="btn" href="/">Altri racconti</a></div></article>
