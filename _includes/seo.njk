{% set seoTitle = title or seoDefaultTitle or "Blog | Photo 10.5" %}
{% set seoDescription = description or seoDefaultDescription or "Contenuti editoriali Photo 10.5." %}
{% set seoSchemaType = seoType or "CollectionPage" %}
{% set seoPageUrl = page.url | absoluteUrl(site.url) %}
{% set seoImageUrl = (cover or site.defaultImage) | absoluteUrl(site.url) %}
{% set seoRootUrl = "/" | absoluteUrl(site.url) %}
<title>{{ seoTitle | escape }}</title>
<meta name="description" content="{{ seoDescription | escape }}">
<link rel="canonical" href="{{ seoPageUrl | escape }}">
<meta property="og:site_name" content="{{ site.name | escape }}">
<meta property="og:type" content="{% if seoSchemaType == 'BlogPosting' %}article{% else %}website{% endif %}">
<meta property="og:locale" content="{% if language == 'en' %}en_US{% else %}it_IT{% endif %}">
<meta property="og:title" content="{{ seoTitle | escape }}">
<meta property="og:description" content="{{ seoDescription | escape }}">
<meta property="og:url" content="{{ seoPageUrl | escape }}">
<meta property="og:image" content="{{ seoImageUrl | escape }}">
<meta property="og:image:alt" content="{{ seoTitle | escape }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seoTitle | escape }}">
<meta name="twitter:description" content="{{ seoDescription | escape }}">
<meta name="twitter:image" content="{{ seoImageUrl | escape }}">
<meta name="twitter:image:alt" content="{{ seoTitle | escape }}">
{% if seoSchemaType == "BlogPosting" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ seoTitle | jsonLd | safe }},
  "description": {{ seoDescription | jsonLd | safe }},
  "url": {{ seoPageUrl | jsonLd | safe }},
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": {{ seoPageUrl | jsonLd | safe }}
  },
  "image": [{{ seoImageUrl | jsonLd | safe }}],
  {% if date %}"datePublished": {{ date | isoDate | jsonLd | safe }},{% endif %}
  "author": {
    "@type": "Person",
    "name": {{ site.authorName | jsonLd | safe }},
    "url": {{ site.publisherUrl | jsonLd | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.publisherName | jsonLd | safe }},
    "url": {{ site.publisherUrl | jsonLd | safe }}
  }
}
</script>
{% else %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": {{ seoSchemaType | jsonLd | safe }},
  "name": {{ seoTitle | jsonLd | safe }},
  "description": {{ seoDescription | jsonLd | safe }},
  "url": {{ seoPageUrl | jsonLd | safe }},
  "image": {{ seoImageUrl | jsonLd | safe }},
  "isPartOf": {
    "@type": "WebSite",
    "name": {{ site.name | jsonLd | safe }},
    "url": {{ seoRootUrl | jsonLd | safe }}
  }
}
</script>
{% endif %}
{% if sectionUrl %}
{% set seoSectionUrl = sectionUrl | absoluteUrl(site.url) %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Blog",
      "item": {{ seoRootUrl | jsonLd | safe }}
    }{% if sectionUrl != "/" %},
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ sectionLabel | jsonLd | safe }},
      "item": {{ seoSectionUrl | jsonLd | safe }}
    }{% endif %}{% if seoSchemaType == "BlogPosting" %},
    {
      "@type": "ListItem",
      "position": {% if sectionUrl != "/" %}3{% else %}2{% endif %},
      "name": {{ seoTitle | jsonLd | safe }},
      "item": {{ seoPageUrl | jsonLd | safe }}
    }{% endif %}
  ]
}
</script>
{% endif %}
